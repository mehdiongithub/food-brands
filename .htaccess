RewriteEngine On
# RewriteBase intentionally omitted so this works no matter what your
# project folder is named (Apache infers it from this file's location).
# If pretty URLs (e.g. /brands, /brand/kfc) 404 on your server, uncomment
# the line below and set it to your ACTUAL folder name:
# RewriteBase /your-folder-name/

# Serve real files and directories as-is
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Home page
RewriteRule ^$ index.php [L]

# Brands listing
RewriteRule ^brands/?$ brands.php [L]

# Brand detail: /brand/crsa
RewriteRule ^brand/([^/]+)/?$ brand.php?slug=$1 [L,QSA]

# Product detail: /product/pizza
RewriteRule ^product/([^/]+)/?$ product.php?slug=$1 [L,QSA]

# Categories listing
RewriteRule ^categories/?$ categories.php [L]

# Category detail: /category/pakistan
RewriteRule ^category/([^/]+)/?$ category.php?slug=$1 [L,QSA]

# Offers
RewriteRule ^offers/?$ offers.php [L]

# Offer detail: /offers/some-offer-slug
RewriteRule ^offers/([^/]+)/?$ offer-detail.php?slug=$1 [L,QSA]

# FAQ
RewriteRule ^faq/?$ faq.php [L]

# Contact
RewriteRule ^contact/?$ contact.php [L]

# About
RewriteRule ^about/?$ about.php [L]

# Search
RewriteRule ^search/?$ search.php [L,QSA]

# Blog listing
RewriteRule ^blog/?$ blog.php [L]

# Blog detail: /blog/some-slug
RewriteRule ^blog/([^/]+)/?$ blog-detail.php?slug=$1 [L,QSA]

# 404 - catch all unmatched routes
RewriteRule ^(.*)$ 404.php [L]